#!/bin/bash
set -eu

mkdir -p "${HOME}/.local/bin"

# mise（バージョン固定）
MISE_VERSION="v2026.5.13"
if ! command -v mise &> /dev/null; then
  echo "==> Installing mise ${MISE_VERSION}..."
  installer="$(mktemp)"
  curl --proto '=https' --tlsv1.2 -sSf -o "${installer}" https://mise.run
  MISE_VERSION="${MISE_VERSION}" sh "${installer}"
  export PATH="${HOME}/.local/bin:${PATH}"
fi

# sheldon (公式スクリプト)
if ! command -v sheldon &> /dev/null; then
  echo "==> Installing sheldon..."
  installer="$(mktemp)"
  curl --proto '=https' -fLsS -o "${installer}" https://rossmacarthur.github.io/install/crate.sh
  bash "${installer}" --repo rossmacarthur/sheldon --to ~/.local/bin
fi

# herdr
if ! command -v herdr &> /dev/null; then
  echo "==> Installing herdr..."
  os="$(uname -s)"
  case "$os" in
    Linux) herdr_os="linux" ;;
    Darwin) herdr_os="macos" ;;
    *) echo "unsupported OS for herdr: $os" >&2; exit 1 ;;
  esac

  arch="$(uname -m)"
  case "$arch" in
    x86_64|amd64) herdr_arch="x86_64" ;;
    aarch64|arm64) herdr_arch="aarch64" ;;
    *) echo "unsupported architecture for herdr: $arch" >&2; exit 1 ;;
  esac

  manifest="$(curl --proto '=https' --tlsv1.2 -fsSL https://herdr.dev/latest.json)"
  target="\"${herdr_os}-${herdr_arch}\""
  url="$(printf '%s\n' "$manifest" | awk -v target="$target" '
    /^[[:space:]]*"assets"[[:space:]]*:/ { in_assets = 1; next }
    in_assets && /^[[:space:]]*}/ { exit }
    in_assets && index($0, target) {
      sub(/^.*:[[:space:]]*"/, "")
      sub(/".*$/, "")
      print
      exit
    }
  ')"
  if [ -z "$url" ]; then
    echo "herdr release manifest does not include ${herdr_os}-${herdr_arch}" >&2
    exit 1
  fi

  binary="$(mktemp)"
  curl --proto '=https' --tlsv1.2 -fsSL -o "$binary" "$url"
  chmod +x "$binary"
  mv "$binary" "${HOME}/.local/bin/herdr"
fi
